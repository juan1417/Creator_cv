# Copia a .env y rellena los valores (ver .gitignore: .env no se versiona)
#
# GEMINI_* → solo el proceso MCP creator_cv.mcp.gemini_server (Cursor). La app Flask no llama a Gemini.
# La entrevista en /interview/mcp lee un archivo por CV: cv-interview.cv<id>.pending.json (ver carpeta context/).
# Opcional: CREATOR_CV_INTERVIEW_PENDING_PATH=/ruta/absoluta/cv-interview.cv{id}.pending.json o .../carpeta/ (un JSON por id).
GEMINI_API_KEY=tu_clave_aqui
GEMINI_MODEL=gemini-2.0-flash

# Si es 0, no se crea solo el primer pending al abrir /interview/mcp (solo MCP o botón manual).
CREATOR_CV_INTERVIEW_AUTO_FIRST_PENDING=1
