{
  "mcpServers": {
    "creator-cv-context": {
      "command": "uv",
      "args": [
        "run",
        "--group",
        "mcp",
        "--directory",
        "REPLACE_WITH_ABSOLUTE_PATH_TO_REPO",
        "python",
        "-m",
        "creator_cv.mcp.fs_server",
        "REPLACE_WITH_ABSOLUTE_PATH_TO_REPO/mcp-ia-preguntas/context"
      ]
    },
    "creator-cv-gemini": {
      "command": "uv",
      "args": [
        "run",
        "--group",
        "mcp",
        "--directory",
        "REPLACE_WITH_ABSOLUTE_PATH_TO_REPO",
        "python",
        "-m",
        "creator_cv.mcp.gemini_server"
      ],
      "env": {
        "GEMINI_API_KEY": "REPLACE_WITH_GOOGLE_AI_STUDIO_KEY",
        "GEMINI_MODEL": "gemini-2.0-flash"
      }
    }
  }
}
