# Creator CV — Backend environment variables

# Database (default: SQLite). Cambiar a PostgreSQL para producción:
# DATABASE_URL=postgresql://user:pass@host:5432/creator_cv
DATABASE_URL=

# JWT secret key. ¡Cambiar en producción!
JWT_SECRET_KEY=dev-secret-key-change-in-prod

# CORS origins (separados por coma)
CORS_ORIGINS=*

# Flask
FLASK_ENV=development
