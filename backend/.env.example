# Creator CV — Backend environment variables

# ─── Database ─────────────────────────────────────────────────────────────
# Default: SQLite local en backend/data/creator_cv.sqlite3 (solo dev/tests).
#
# Para usar Neon (Postgres):
#   1. Crear el branch:    npx neonctl@latest init
#   2. Copiar la URL que imprime Neon (algo como
#      postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require)
#   3. Pegar acá. El backend agrega el driver `psycopg` y `sslmode=require`
#      automáticamente si faltan.
#   4. Aplicar migraciones: uv run alembic upgrade head
#
DATABASE_URL=

# ─── JWT secret key ──────────────────────────────────────────────────────
# ¡Cambiar en producción! Generar uno con: openssl rand -hex 32
JWT_SECRET_KEY=dev-secret-key-change-in-prod

# TTL del access token en minutos. Default 15. Subir a 60-120 si tenés UX
# molesta por expiraciones frecuentes. Los refresh tokens (Phase 2) absorben
# la necesidad de loguear repetidamente.
ACCESS_TOKEN_TTL_MINUTES=15

# ─── CORS ────────────────────────────────────────────────────────────────
# Lista separada por coma, o "*" para todos.
CORS_ORIGINS=*

# ─── Flask ──────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=0
LOG_LEVEL=INFO

# ─── 2FA / TOTP ──────────────────────────────────────────────────────────
# Fernet key para encrypt de TOTP secrets at rest. Generar con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ¡Cambiar en producción! Rotar periódicamente invalida los 2FA secrets existentes.
ENCRYPTION_KEY=

# Label que ve el usuario en su app authenticator (Google Authenticator, Authy, etc.)
TOTP_ISSUER=Creator CV
